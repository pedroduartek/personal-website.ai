{
  "rewrites": [
    {
      "source": "/favicon",
      "destination": "/favicon.png"
    },
    {
      "source": "/sitemap",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}